[database]
# Do not commit your real config.conf with live credentials.
# Prefer HASHCRUSH_DATABASE_URI in production. If uri is empty, HashCrush falls
# back to the discrete PostgreSQL fields below.
uri =
host = 127.0.0.1
port = 5432
name = hashcrush
username = username
password = password

[app]
# Optional: set a stable app secret key here (or via HASHCRUSH_SECRET_KEY env var).
secret_key =
# Required for app-level encryption of persisted hashes/plaintexts/usernames.
# Prefer HASHCRUSH_DATA_ENCRYPTION_KEY in production.
data_encryption_key =
# Optional: absolute path or command name for local hashcat binary.
hashcat_bin = hashcat
# Optional: hashcat --status timer interval in seconds.
hashcat_status_timer = 5
# Optional: hashfile validator limits.
hashfile_max_line_length = 50000
hashfile_max_total_lines = 1000000
hashfile_max_total_bytes = 1073741824
# Optional: runtime artifact root (tmp/hashes/outfiles). Default uses system temp.
runtime_path = /tmp/hashcrush-runtime
# Optional: persistent uploaded asset root (wordlists/rules). Default is a dedicated app storage directory.
storage_path = /var/lib/hashcrush
# Optional: SSL cert/key file paths (or set HASHCRUSH_SSL_CERT_PATH / HASHCRUSH_SSL_KEY_PATH).
ssl_cert_path = /etc/hashcrush/ssl/cert.pem
ssl_key_path = /etc/hashcrush/ssl/key.pem
# Optional: login brute-force throttle controls.
auth_throttle_enabled = true
auth_throttle_max_attempts = 5
auth_throttle_window_seconds = 300
auth_throttle_lockout_seconds = 900
# Optional: only enable behind a trusted reverse proxy that sanitizes this header.
trust_x_forwarded_for = false
# Optional: session cookie hardening controls.
session_cookie_secure = true
session_cookie_httponly = true
session_cookie_samesite = Lax
