{% extends "setup_base.html.j2" %}


{% from "macros.j2" import make_form_group with context %}


{% block content %}
<h2 style="margin-top: 1rem; margin-bottom: 1rem;">Set Initial Settings</h2>
<div class="content-section">
    <form method="POST" action="/setup/settings">
        {{ form.hidden_tag() }}
        <p class="text-muted">Runtime caps are disabled. Save to initialize default settings.</p>
        <div class="form-group">
            {{ form.submit(class="btn btn-primary pull-right")}}
        </div>
    </form>
</div>
{% endblock %}
