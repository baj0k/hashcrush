# Copy to .env.test and edit the password placeholders.
# Or run: python3 ./hashcrush.py setup --test
# hashcrush.py setup --test writes a ready-to-use .env.test automatically.
# tests/conftest.py auto-loads .env.test for E2E runs.

HASHCRUSH_E2E_BASE_URL="https://127.0.0.1:8443"
HASHCRUSH_E2E_VERIFY_TLS=0

# Primary admin account used by E2E login/setup flows.
HASHCRUSH_E2E_USERNAME="admin"
HASHCRUSH_E2E_PASSWORD="<set-admin-password>"

# Optional setup-flow values if the app is still uninitialized.
HASHCRUSH_E2E_SETUP_USERNAME="admin"
HASHCRUSH_E2E_SETUP_PASSWORD="<set-admin-password>"

# Secondary non-admin account used by authorization/IDOR checks.
HASHCRUSH_E2E_SECOND_USERNAME="test"
HASHCRUSH_E2E_SECOND_PASSWORD="<set-second-user-password>"
HASHCRUSH_E2E_SECOND_IS_ADMIN=0

# Recommended IDs can be printed with:
#   python3 ./scripts/print_e2e_context.py
HASHCRUSH_E2E_DOMAIN_ID="1"
HASHCRUSH_E2E_DOMAIN_NAME="E2E Domain"
HASHCRUSH_E2E_HASHFILE_ID="1"
HASHCRUSH_E2E_TASK_ID="1"
HASHCRUSH_E2E_TASK_NAME="?a [1]"
