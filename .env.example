# Copy to .env and fill in before running docker compose.
# Nginx setup
HASHCRUSH_HTTPS_PORT=8443

# Hashcrush setup
COMPOSE_PROJECT_NAME=hashcrush
POSTGRES_DB=hashcrush
POSTGRES_USER=hashcrush
POSTGRES_PASSWORD=
HASHCRUSH_SECRET_KEY=
HASHCRUSH_DATA_ENCRYPTION_KEY=
HASHCRUSH_INITIAL_ADMIN_USERNAME=admin
HASHCRUSH_INITIAL_ADMIN_PASSWORD=

# Wordlists, rules, and HIBP datasets are registered from these mounts (no browser uploads).
HASHCRUSH_EXTERNAL_WORDLISTS_HOST_PATH=/srv/hashcrush/wordlists
HASHCRUSH_RULES_HOST_PATH=/srv/hashcrush/rules
HASHCRUSH_HIBP_DATASETS_HOST_PATH=/srv/hashcrush/hibp
