# Copy to .env and replace these placeholder values before running docker compose.
COMPOSE_PROJECT_NAME=hashcrush
POSTGRES_DB=hashcrush
POSTGRES_USER=hashcrush
POSTGRES_PASSWORD=
HASHCRUSH_SECRET_KEY=
HASHCRUSH_DATA_ENCRYPTION_KEY=
HASHCRUSH_INITIAL_ADMIN_USERNAME=admin
HASHCRUSH_INITIAL_ADMIN_PASSWORD=
# Published host port for the HTTPS nginx reverse proxy.
HASHCRUSH_HTTPS_PORT=8443
HASHCRUSH_TRUST_X_FORWARDED_FOR=1
# Optional: override the bundled worker Hashcat version.
# HASHCRUSH_HASHCAT_VERSION=7.1.2
