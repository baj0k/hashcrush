# Ignore everything by default.
*

# Allow nested allowlist rules.
!*/

# Repository metadata and docs
!.gitignore
!LICENSE
!README.md
!TODO.md

# Project configuration and entry points
!pyproject.toml
!pytest.ini
!requirements.txt
!requirements-test.txt
!hashcrush.py
!bootstrap_cli.py
!Dockerfile
!compose.yaml
!.dockerignore

# Application source and frontend assets
!hashcrush/**/*.py
!hashcrush/templates/**
!hashcrush/static/**
!hashcrush/config.conf.example

# Tests and test fixtures/scripts
!tests/**/*.py
!tests/**/*.txt
!tests/**/*.sh
