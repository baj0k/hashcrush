# Ignore everything by default.
*

# Allow nested allowlist rules.
!*/

# Repository metadata and docs
!.gitignore
!.pylintrc
!LICENSE
!README.md

# Project configuration and entry points
!Dockerfile
!docker-compose.yml
!pyproject.toml
!pytest.ini
!requirements.txt
!requirements-test.txt
!hashcrush.py
!bootstrap_cli.py

# Application source and frontend assets
!hashcrush/**/*.py
!hashcrush/templates/**
!hashcrush/static/**
!hashcrush/config.conf.example

# Tests and test fixtures/scripts
!tests/**/*.py
!tests/**/*.txt
!tests/**/*.sh
